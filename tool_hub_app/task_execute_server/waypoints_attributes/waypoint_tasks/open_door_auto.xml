<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="WaitForElevator">
      <!-- 使用默认参数 -->
      <!--StopPlayback service_name="stop_playback"/-->
      <!--DoorControl service_name="/door_control" executeid="1" success="{door_success}" stateid="{door_state}"/-->
      
      <RetryUntilSuccessful num_attempts="10">
        
        <Sequence name="CallAndCheckDoor">
        <PublishTaskStatus status_code="300"/>
        <DoorControl service_name="/door_control" doorid="2" executeid="2" success="{door_success}" stateid="{door_state}"/>           
        
        </Sequence>
      </RetryUntilSuccessful>
      <PublishTaskStatus status_code="303"/>
    </Sequence>
  </BehaviorTree>
</root>
